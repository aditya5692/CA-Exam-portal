generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                    @id @default(cuid())
  email                 String?                   @unique
  fullName              String?
  registrationNumber    String?                   @unique
  department            String?
  phone                 String?                   @unique
  otp                   String?
  otpExpiresAt          DateTime?
  preferredLanguage     String?
  timezone              String?
  bio                   String?
  designation           String?
  expertise             String?
  examTarget            String?
  examTargetLevel       String?
  examTargetMonth       Int?
  examTargetYear        Int?
  role                  String                    @default("STUDENT")
  storageUsed           Int                       @default(0)
  storageLimit          Int                       @default(52428800)
  plan                  String                    @default("FREE")
  planExpiresAt         DateTime?
  passwordHash          String?
  isSuperAdmin          Boolean                   @default(false)
  isBlocked             Boolean                   @default(false)
  blockedReason         String?
  isPublicProfile       Boolean                   @default(true)
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  loginCount            Int                       @default(0)
  batch                 String?
  dob                   String?
  location              String?
  firm                  String?
  firmRole              String?
  articleshipYear       Int?
  articleshipTotal      Int?
  foundationCleared     Boolean                   @default(false)
  intermediateCleared   Boolean                   @default(false)
  finalCleared          Boolean                   @default(false)
  resumeUrl             String?
  authToken             String?
  articleshipFirmType   String?
  city                  String?
  experienceYears       Int?
  state                 String?
  announcements         Announcement[]            @relation("TeacherAnnouncements")
  batchesTeaching       Batch[]                   @relation("TeacherBatches")
  teacherCaseStudies    CaseStudy[]               @relation("TeacherCaseStudies")
  studentChapterMarkers ChapterCompletionMarker[] @relation("StudentChapterMarkers")
  dailyTargets          DailyTargetQueue[]        @relation("StudentDailyTargets")
  draftMCQs             DraftMCQ[]                @relation("DraftMCQs")
  enrollments           Enrollment[]
  examsCreated          Exam[]                    @relation("TeacherExams")
  examAttempts          ExamAttempt[]
  folders               Folder[]
  teacherGlobalMCQs     GlobalMCQBank[]           @relation("TeacherGlobalMCQs")
  teacherMasterBatches  MasterBatch[]             @relation("InitiatorMasterBatches")
  materialAccess        MaterialAccess[]
  notifications         Notification[]            @relation("UserNotifications")
  ownedQuestions        Question[]                @relation("TeacherOwnedQuestions")
  savedItems            SavedItem[]               @relation("StudentSavedItems")
  sessions              Session[]
  studentClaimedCodes   StudentAccessCode[]       @relation("StudentClaimedCodes")
  teacherAccessCodes    StudentAccessCode[]       @relation("TeacherAccessCodes")
  studentActivityLogs   StudentActivityLog[]      @relation("StudentActivityLogs")
  learningProfile       StudentLearningProfile?
  materialsUploaded     StudyMaterial[]           @relation("UploadedMaterials")
  subscriptions         Subscription[]
  topicProgress         TopicProgress[]
  featureOverrides      UserFeatureAccess[]
  userProgress          UserProgress[]
  xpEvents              XPEvent[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  lastActiveAt DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserProgress {
  id             String   @id @default(cuid())
  userId         String
  resourceType   String
  resourceId     String
  data           Json
  lastAccessedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceType, resourceId])
  @@index([userId, updatedAt(sort: Desc)])
}

model StudyMaterial {
  id           String           @id @default(cuid())
  title        String
  description  String?
  fileUrl      String
  fileType     String
  sizeInBytes  Int
  isPublic     Boolean          @default(false)
  isProtected  Boolean          @default(true)
  category     String           @default("GENERAL")
  subType      String           @default("PDF")
  providerType String           @default("PLATFORM")
  downloads    Int              @default(0)
  shareCount   Int              @default(0)
  rating       Float            @default(5.0)
  isTrending   Boolean          @default(false)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  uploadedById String
  folderId     String?
  batches      BatchMaterial[]
  accessedBy   MaterialAccess[]
  folder       Folder?          @relation(fields: [folderId], references: [id])
  uploadedBy   User             @relation("UploadedMaterials", fields: [uploadedById], references: [id])
}

model BatchMaterial {
  id         String        @id @default(cuid())
  batchId    String
  materialId String
  material   StudyMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  batch      Batch         @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, materialId])
}

model Folder {
  id         String          @id @default(cuid())
  name       String
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  ownerId    String
  parentId   String?
  parent     Folder?         @relation("SubFolders", fields: [parentId], references: [id])
  subFolders Folder[]        @relation("SubFolders")
  owner      User            @relation(fields: [ownerId], references: [id])
  materials  StudyMaterial[]
}

model MaterialAccess {
  id         String        @id @default(cuid())
  grantedAt  DateTime      @default(now())
  accessType String        @default("FREE_BATCH_MATERIAL")
  studentId  String
  materialId String
  material   StudyMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)
  student    User          @relation(fields: [studentId], references: [id])

  @@unique([studentId, materialId])
}

model SavedItem {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  type       String   @default("MATERIAL")
  studentId  String
  resourceId String
  student    User     @relation("StudentSavedItems", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, resourceId, type])
}

model Batch {
  id                String                    @id @default(cuid())
  name              String
  uniqueJoinCode    String                    @unique
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  teacherId         String
  masterId          String?
  subjectId         String?
  announcements     Announcement[]
  subject           Subject?                  @relation(fields: [subjectId], references: [id])
  masterBatch       MasterBatch?              @relation(fields: [masterId], references: [id])
  teacher           User                      @relation("TeacherBatches", fields: [teacherId], references: [id])
  batchMaterials    BatchMaterial[]
  completionMarkers ChapterCompletionMarker[]
  enrollments       Enrollment[]
  exams             Exam[]                    @relation("BatchExams")
  batchAccessCodes  StudentAccessCode[]       @relation("BatchAccessCodes")
}

model Enrollment {
  id        String   @id @default(cuid())
  joinedAt  DateTime @default(now())
  studentId String
  batchId   String
  status    String   @default("ACTIVE")
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id])

  @@unique([studentId, batchId])
}

model Announcement {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  batchId   String
  teacherId String
  teacher   User     @relation("TeacherAnnouncements", fields: [teacherId], references: [id])
  batch     Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
}

model DraftMCQ {
  id        String   @id @default(cuid())
  question  String
  options   String
  answer    String
  createdAt DateTime @default(now())
  teacherId String
  teacher   User     @relation("DraftMCQs", fields: [teacherId], references: [id])
}

model UserFeatureAccess {
  id           String   @id @default(cuid())
  featureKey   String
  isEnabled    Boolean  @default(true)
  isRestricted Boolean  @default(false)
  canRead      Boolean  @default(true)
  canCreate    Boolean  @default(false)
  canUpdate    Boolean  @default(false)
  canDelete    Boolean  @default(false)
  canShare     Boolean  @default(false)
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, featureKey])
}

model Exam {
  id                    String         @id @default(cuid())
  title                 String
  description           String?
  duration              Int            @default(60)
  totalMarks            Int            @default(0)
  passingMarks          Int            @default(0)
  category              String         @default("GENERAL")
  subject               String?
  chapter               String?
  status                String         @default("DRAFT")
  examType              String         @default("GENERAL")
  isFeatured            Boolean        @default(false)
  visibleToNonBatch     Boolean        @default(false)
  visibleToOtherBatches Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  teacherId             String
  batchId               String?
  batch                 Batch?         @relation("BatchExams", fields: [batchId], references: [id])
  teacher               User           @relation("TeacherExams", fields: [teacherId], references: [id])
  attempts              ExamAttempt[]
  questions             ExamQuestion[]
}

model Question {
  id             String          @id @default(cuid())
  text           String
  type           String          @default("MCQ")
  explanation    String?
  difficulty     String          @default("MEDIUM")
  subject        String?
  topic          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  teacherId      String?
  caseStudyId    String?
  exams          ExamQuestion[]
  options        Option[]
  caseStudy      CaseStudy?      @relation(fields: [caseStudyId], references: [id])
  teacher        User?           @relation("TeacherOwnedQuestions", fields: [teacherId], references: [id])
  studentAnswers StudentAnswer[]
}

model CaseStudy {
  id                 String          @id @default(cuid())
  title              String
  content            String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  teacherId          String?
  applicableAttempts String          @default("[]")
  scenarioImageUrl   String?
  teacher            User?           @relation("TeacherCaseStudies", fields: [teacherId], references: [id])
  linkedMcqs         GlobalMCQBank[]
  questions          Question[]
}

model Option {
  id             String          @id @default(cuid())
  text           String
  isCorrect      Boolean         @default(false)
  questionId     String
  question       Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentAnswers StudentAnswer[]
}

model ExamQuestion {
  id         String   @id @default(cuid())
  order      Int      @default(0)
  marks      Int      @default(1)
  examId     String
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([examId, questionId])
}

model ExamAttempt {
  id          String          @id @default(cuid())
  startTime   DateTime        @default(now())
  endTime     DateTime?
  score       Float           @default(0)
  status      String          @default("STARTED")
  attemptMode String          @default("MOCK")
  studentId   String
  examId      String
  exam        Exam            @relation(fields: [examId], references: [id], onDelete: Cascade)
  student     User            @relation(fields: [studentId], references: [id])
  answers     StudentAnswer[]
}

model StudentAnswer {
  id               String      @id @default(cuid())
  isCorrect        Boolean     @default(false)
  timeSpent        Int         @default(0)
  attemptId        String
  questionId       String
  selectedOptionId String?
  gapTag           String?
  selectedOption   Option?     @relation(fields: [selectedOptionId], references: [id])
  question         Question    @relation(fields: [questionId], references: [id])
  attempt          ExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model StudentLearningProfile {
  id             String          @id @default(cuid())
  totalXP        Int             @default(0)
  level          Int             @default(1)
  streak         Int             @default(0)
  longestStreak  Int             @default(0)
  totalAttempts  Int             @default(0)
  totalCorrect   Int             @default(0)
  avgAccuracy    Float           @default(0)
  weakTopicsJson Json            @default("[]")
  badgesJson     Json            @default("[]")
  lastAttemptAt  DateTime?
  practiceGoal   Int             @default(20)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  studentId      String          @unique
  student        User            @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topicProgress  TopicProgress[]
  xpEvents       XPEvent[]
}

model TopicProgress {
  id             String                 @id @default(cuid())
  subject        String
  topic          String
  totalAttempted Int                    @default(0)
  totalCorrect   Int                    @default(0)
  accuracy       Float                  @default(0)
  avgTimeSpent   Float                  @default(0)
  lastSeenAt     DateTime               @default(now())
  nextReviewAt   DateTime               @default(now())
  difficulty     String                 @default("MEDIUM")
  studentId      String
  profileId      String
  profile        StudentLearningProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  student        User                   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subject, topic])
}

model XPEvent {
  id        String                 @id @default(cuid())
  xpDelta   Int
  reason    String
  meta      String                 @default("")
  createdAt DateTime               @default(now())
  studentId String
  profileId String
  profile   StudentLearningProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  student   User                   @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("SYSTEM")
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id                     String    @id @default(cuid())
  plan                   String
  role                   String
  status                 String    @default("ACTIVE")
  amountPaise            Int
  razorpayOrderId        String?   @unique
  razorpayPaymentId      String?   @unique
  razorpaySignature      String?
  razorpaySubscriptionId String?   @unique
  razorpayPlanId         String?
  cancelAtPeriodEnd      Boolean   @default(false)
  grantedByAdminId       String?
  startedAt              DateTime  @default(now())
  expiresAt              DateTime
  currentPeriodEnd       DateTime?
  createdAt              DateTime  @default(now())
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model PlatformConfig {
  id                    String   @id @default(cuid())
  singletonKey          String   @unique @default("default")
  msg91AuthKey          String?
  msg91WidgetId         String?
  msg91OtpTemplateId    String?
  msg91TokenAuth        String?
  razorpayKeyId         String?
  razorpayKeySecret     String?
  razorpayWebhookSecret String?
  razorpayPlanBasic     String?
  razorpayPlanPro       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model StudentAccessCode {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  email     String
  caLevel   String?
  subject   String?
  status    String   @default("PENDING")
  isEmailed Boolean  @default(false)
  teacherId String
  batchId   String?
  studentId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   User?    @relation("StudentClaimedCodes", fields: [studentId], references: [id])
  batch     Batch?   @relation("BatchAccessCodes", fields: [batchId], references: [id], onDelete: Cascade)
  teacher   User     @relation("TeacherAccessCodes", fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([email])
}

model WebhookEvent {
  id        String   @id @default(cuid())
  eventId   String   @unique
  type      String
  status    String   @default("PROCESSED")
  createdAt DateTime @default(now())
  eventName String?
  payload   Json?

  @@index([eventId])
}

model AccessCode {
  id         String    @id @default(cuid())
  codeString String    @unique
  payload    Json
  usageLimit Int
  usedCount  Int       @default(0)
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
}

model Subject {
  id           String          @id @default(cuid())
  name         String
  icaiLevel    String
  createdAt    DateTime        @default(now())
  childBatches Batch[]
  globalMcqs   GlobalMCQBank[]
}

model GlobalMCQBank {
  id                 String               @id @default(cuid())
  teacherId          String
  subjectId          String
  parentCaseId       String?
  questionText       String
  options            Json
  correctAnswer      String
  explanation        String?
  icaiCategory       String
  sourceTag          String
  applicableAttempts String               @default("[]")
  platformAvgTime    Float                @default(0.0)
  totalAttempts      Int                  @default(0)
  createdAt          DateTime             @default(now())
  dailyTargetQueues  DailyTargetQueue[]
  parentCase         CaseStudy?           @relation(fields: [parentCaseId], references: [id])
  subject            Subject              @relation(fields: [subjectId], references: [id])
  teacher            User                 @relation("TeacherGlobalMCQs", fields: [teacherId], references: [id])
  activityLogs       StudentActivityLog[]
}

model MasterBatch {
  id                 String   @id @default(cuid())
  name               String
  initiatorTeacherId String
  comboExamAttempt   String
  createdAt          DateTime @default(now())
  childBatches       Batch[]
  initiatorTeacher   User     @relation("InitiatorMasterBatches", fields: [initiatorTeacherId], references: [id])
}

model StudentActivityLog {
  id               String        @id @default(cuid())
  studentId        String
  mcqId            String
  isCorrect        Boolean
  timeTakenSeconds Int
  gapTag           String?
  createdAt        DateTime      @default(now())
  mcq              GlobalMCQBank @relation(fields: [mcqId], references: [id])
  student          User          @relation("StudentActivityLogs", fields: [studentId], references: [id])
}

model ChapterCompletionMarker {
  id               String   @id @default(cuid())
  studentId        String
  batchId          String
  chapterId        String
  markedCompleteAt DateTime @default(now())
  childBatch       Batch    @relation(fields: [batchId], references: [id])
  student          User     @relation("StudentChapterMarkers", fields: [studentId], references: [id])

  @@unique([studentId, batchId, chapterId])
}

model DailyTargetQueue {
  id              String        @id @default(cuid())
  studentId       String
  mcqId           String
  isCompleted     Boolean       @default(false)
  targetedForDate DateTime
  priority        String        @default("NORMAL")
  reason          String?
  createdAt       DateTime      @default(now())
  mcq             GlobalMCQBank @relation(fields: [mcqId], references: [id])
  student         User          @relation("StudentDailyTargets", fields: [studentId], references: [id])
}
