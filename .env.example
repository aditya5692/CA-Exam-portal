# Local development from your own machine
# Expose your Dokploy Postgres on an unused host port such as 5433, not 3000.
LOCAL_DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@YOUR_SERVER_IP:5433/DB_NAME

# Dokploy app runtime
# Use the internal Dokploy database host and container port when the app runs inside Dokploy.
DOKPLOY_DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@YOUR_DOKPLOY_DB_HOST:5432/DB_NAME

# Optional override used in any environment.
# DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@HOST:PORT/DB_NAME

# Optional pool tuning
# DATABASE_CONNECT_TIMEOUT_MS=3000
# DATABASE_POOL_MAX=10
