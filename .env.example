# Database
# Local SQLite fallback:
# DATABASE_URL=file:./dev.db
DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@localhost:5432/DB_NAME
DOKPLOY_DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@YOUR_DOKPLOY_DB_HOST:5432/DB_NAME
LOCAL_DATABASE_URL=postgresql://DB_USER:DB_PASSWORD@YOUR_SERVER_IP:5433/DB_NAME
DATABASE_CONNECT_TIMEOUT_MS=3000
DATABASE_POOL_MAX=20
DATABASE_IDLE_TIMEOUT_MS=30000

# Auth
JWT_SECRET=replace-with-a-long-random-secret
# Set this to your shared parent domain in production, for example `.financly.in`
AUTH_COOKIE_DOMAIN=
# Optional dedicated key for encrypting admin-saved runtime secrets.
# If omitted, JWT_SECRET is used instead.
PLATFORM_CONFIG_ENCRYPTION_KEY=

# Firebase Admin (Required for Server-side Phone Auth Verification)
FIREBASE_PROJECT_ID=financly-21966
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase Client (Publicly exposed to browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Runtime integrations
# These can be saved later in Admin > Control Center > Integrations.
# Keep them in env only as bootstrap/fallback values.

# MSG91
# Required for the widget login flow:
MSG91_AUTH_KEY=476487AxML7Btz0p69c7b847P1
MSG91_WIDGET_ID=366341726377313535353337
MSG91_TOKEN_AUTH=476487TXs7Ytqw69c753c5P1
# Optional. Only needed if you still use the fallback server-side OTP template API.
MSG91_OTP_TEMPLATE_ID=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_BASIC=
RAZORPAY_PLAN_PRO=

# Legacy env names still supported as fallback if you already use them:
# NEXT_PUBLIC_MSG91_WIDGET_ID=
# NEXT_PUBLIC_MSG91_TOKEN_AUTH=
# NEXT_PUBLIC_RAZORPAY_KEY_ID=
# NEXT_PUBLIC_RAZORPAY_PLAN_BASIC=
# NEXT_PUBLIC_RAZORPAY_PLAN_PRO=
